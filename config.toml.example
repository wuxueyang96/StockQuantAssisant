# Configuration file for LLM-Driven Quantitative Trading
# Copy this file to config.toml and modify as needed

# Proxy configuration (optional)
# If not specified, no proxy will be used
# Supported formats:
#   - HTTP:  http://proxy.example.com:8080
#   - HTTPS: https://proxy.example.com:8080
#   - SOCKS5: socks5://proxy.example.com:1080 (or socks:// - will be auto-converted)
#   - With authentication: http://username:password@proxy.example.com:8080
# Note: Both socks:// and socks5:// are supported (socks:// is automatically converted to socks5://)
[proxy]
# url = "socks5://127.0.0.1:1080"
# url = "socks://127.0.0.1:1080"  # Also works, will be converted to socks5://

# LLM configuration (optional)
# If not specified, statistical model will be used for predictions
# Supported providers: openai, qwen, deepseek
[llm]
# provider = "openai"  # or "qwen" or "deepseek"
# api_key = "your-api-key-here"
# base_url = "https://api.openai.com/v1/chat/completions"  # Optional, uses default if not specified
# model = "gpt-4"  # Optional, uses default model for provider if not specified

# Example configurations for different providers:

# OpenAI
# [llm]
# provider = "openai"
# api_key = "sk-..."
# model = "gpt-4"  # Optional

# Qwen (Alibaba Cloud)
# [llm]
# provider = "qwen"
# api_key = "sk-..."
# model = "qwen-turbo"  # Optional, default: qwen-turbo

# DeepSeek
# [llm]
# provider = "deepseek"
# api_key = "sk-..."
# model = "deepseek-chat"  # Optional, default: deepseek-chat

